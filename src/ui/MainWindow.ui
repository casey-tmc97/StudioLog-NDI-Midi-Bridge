    <width>520</width>
    <height>210</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>StudioLog NDI MIDI Bridge</string>
  </property>
  <widget class="QWidget" name="centralWidget">
   <layout class="QVBoxLayout" name="verticalLayout">
    <property name="margin">
     <number>12</number>
    </property>
    <property name="spacing">
     <number>8</number>
    </property>

    <!-- ── Timecode display ─────────────────────────────────────────────── -->
    <item>
     <widget class="QLabel" name="timecodeLabel">
      <property name="text">
       <string>--:--:--:--</string>
      </property>
      <property name="alignment">
       <set>Qt::AlignHCenter|Qt::AlignVCenter</set>
      </property>
      <property name="font">
       <font>
        <family>Consolas</family>
        <pointsize>36</pointsize>
        <bold>true</bold>
       </font>
      </property>
     </widget>
    </item>

    <!-- ── State / status label ────────────────────────────────────────── -->
    <item>
     <widget class="QLabel" name="stateLabel">
      <property name="text">
       <string>Idle</string>
      </property>
      <property name="alignment">
       <set>Qt::AlignHCenter</set>
      </property>
     </widget>
    </item>

    <!-- ── Setup panel (NDI source, MIDI port, channel) ────────────────── -->
    <item>
     <widget class="QGroupBox" name="setupGroup">
      <property name="title">
       <string>Setup</string>
      </property>
      <layout class="QFormLayout" name="formLayout">

       <item row="0" column="0">
        <widget class="QLabel" name="ndiLabel">
         <property name="text"><string>NDI Source:</string></property>
        </widget>
       </item>
       <item row="0" column="1">
        <widget class="QComboBox" name="ndiCombo">
         <property name="toolTip">
          <string>Select the NDI source broadcasting SMPTE LTC audio</string>
         </property>
        </widget>
       </item>

       <item row="1" column="0">
        <widget class="QLabel" name="midiLabel">
         <property name="text"><string>MIDI Port:</string></property>
        </widget>
       </item>
       <item row="1" column="1">
        <widget class="QComboBox" name="midiCombo">
         <property name="toolTip">
          <string>Select the loopMIDI virtual port to send MTC to (Windows) or CoreMIDI virtual port (macOS)</string>
         </property>
        </widget>
       </item>

       <item row="2" column="0">
        <widget class="QLabel" name="channelLabel">
         <property name="text"><string>LTC Channel:</string></property>
        </widget>
       </item>
       <item row="2" column="1">
        <widget class="QComboBox" name="channelCombo">
         <item><property name="text"><string>Auto-detect</string></property></item>
         <item><property name="text"><string>Left (Ch 1)</string></property></item>
         <item><property name="text"><string>Right (Ch 2)</string></property></item>
        </widget>
       </item>

      </layout>
     </widget>
    </item>

